{
  "compilerOptions": {
      "allowJs": false,
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true,
      "declaration": true,
      "sourceMap": true,
      "module": "preserve",
      "moduleResolution": "bundler",
      "target": "ES2022",
      "strict": true,
      "noEmitOnError": true,
      "declarationMap": true,
      // Required due to type errors in powerbi-visuals-api declarations. Can be removed once they are fixed upstream.
      "skipLibCheck": true,
      "lib": [
          "es2022",
          "dom"
      ],
      "rootDir": "./src",
      "outDir": "./lib"
  },
  "include": [
      "src/**/*.ts"
  ]
}
