{
  "compilerOptions": {
      "allowJs": false,
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true,
      "declaration": true,
      "sourceMap": true,
      "module": "ES2020",
      "moduleResolution": "bundler",
      "target": "ES2020",
      "strict": true,
      "strictNullChecks": false,
      "strictPropertyInitialization": false,
      "noImplicitAny": false,
      "forceConsistentCasingInFileNames": true,
      "noEmitOnError": true,
      // Required due to type errors in powerbi-visuals-api declarations. Can be removed once they are fixed upstream.
      "skipLibCheck": true,
      "lib": [
          "es2020",
          "dom"
      ],
      "rootDir": "./src",
      "outDir": "./lib"
  },
   "include": [
      "src/**/*.ts"
    ]
}
